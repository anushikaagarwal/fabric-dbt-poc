# Copy to ~/.dbt/profiles.yml or configure equivalent settings in Fabric dbt job UI.

fabric_implementation_poc:
  target: fabric_dev
  outputs:
    fabric_dev:
      authentication: CLI
      type: fabric
      driver: 'ODBC Driver 18 for SQL Server'
      database: WH_FabricDBTTest
      schema: BI_LAYER_FABRIC_POC
      threads: 4
      host: "{{ env_var('FABRIC_HOST_STRING') }}"

    snowflake_dev:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      role: "{{ env_var('SNOWFLAKE_ROLE') }}"
      database: edh_publish
      warehouse: "{{ env_var('SNOWFLAKE_WAREHOUSE') }}"
      schema: BI_LAYER_FABRIC_POC
      threads: 4
      authenticator: externalbrowser
